{
  "name": "orrery",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "npm run dev:app",
    "dev:app": "concurrently -k \"vite --host 127.0.0.1 --port 5173 --strictPort\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "dev:web": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "runtime:spike": "node scripts/claude-stream-json-spike.mjs finish",
    "runtime:spike:kill": "node scripts/claude-stream-json-spike.mjs kill",
    "runtime:membrane:smoke": "node scripts/membrane-smoke.mjs",
    "runtime:membrane:validation": "node scripts/membrane-validation.mjs",
    "runtime:canvas:orchestration": "node scripts/canvas-orchestration-smoke.mjs",
    "runtime:master-loop": "node scripts/master-loop-smoke.mjs",
    "runtime:persistence": "node scripts/runtime-persistence-recovery.mjs",
    "runtime:codex-interaction": "node scripts/codex-interaction-smoke.mjs",
    "preview": "vite preview",
    "start": "electron ."
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.191",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@pierre/diffs": "^1.2.11",
    "@tailwindcss/vite": "^4.3.1",
    "@xyflow/react": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "radix-ui": "^1.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.5.0",
    "oxlint": "^1.69.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "wait-on": "^9.0.10"
  }
}
